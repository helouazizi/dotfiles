" Enable syntax highlighting and line numbers
syntax on
set number

" Crucial DevOps Indentation Settings (Prevents YAML breakages)
set tabstop=2        " A tab counts for 2 spaces
set shiftwidth=2     " Auto-indent uses 2 spaces
set expandtab        " Converts Tabs to actual spaces
set autoindent       " Copy indent from current line when starting a new line

" Quality of Life
set mouse=a          " Enable mouse scrolling/clicking in terminal
set hlsearch         " Highlight search matches